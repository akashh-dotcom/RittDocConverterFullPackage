<sect1 id="ch0005s0001" role="auto-generated">
         <title>5. Unprovoked</title>
         <sidebar id="ch0005s0001ad01" role="FormalPara FormalParaRenderingStyle3">
            <title>Learning Objectives</title>
            <orderedlist continuation="restarts" inheritnum="ignore">
               <listitem role="ListItem">
                  <para>Explain what it means to be involved in an unprovoked situation.</para>
               </listitem>
               <listitem role="ListItem">
                  <para>Discuss the effects of harming others, both intentionally and unintentionally.</para>
               </listitem>
               <listitem role="ListItem">
                  <para>Determine the potential benefits of healing oneself and discuss if healing oneself is possible.</para>
               </listitem>
               <listitem role="ListItem">
                  <para>Discuss how moving forward can bring closure.</para>
               </listitem>
            </orderedlist>
         </sidebar>
      </sect1>
      
