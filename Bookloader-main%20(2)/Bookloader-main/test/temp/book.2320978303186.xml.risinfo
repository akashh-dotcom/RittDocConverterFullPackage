                  <ulink url="https://www.researchgate.net/publication/372094983_The_influence_of_job_burnout_on_quiet_quitting_among_nurses_the_mediating_effect_of_job_satisfaction">
                     <emphasis role="RefSource">https://www.researchgate.net/publication/372094983_The_influence_of_job_burnout_on_quiet_quitting_among_nurses_the_mediating_effect_of_job_satisfaction</emphasis>
                  </ulink>
