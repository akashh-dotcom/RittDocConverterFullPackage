   <chapter id="ch0004" label="4">
      <title>4. Patients Matter</title>
      <sect1 id="ch0004s0012">
         <sect1info>
            <risinfo>
               <booktitle>How Can Nurses Survive Bullying Environments?</booktitle>
               <isbn>2320978303186</isbn>
               <chapternumber>4</chapternumber>
               <chapterid>ch0004</chapterid>
               <chaptertitle>4. Patients Matter</chaptertitle>
               <authorgroup>
                  <author>
                     <personname>
                        <firstname>Cheryl</firstname>
                        <surname>Green</surname>
                     </personname>
                  </author>
               </authorgroup>
