   <chapter id="ch0013" label="13">
      <title>How Can Nurses Survive Bullying Environments?</title>
      <sect1 id="ch0013s0001">
         <sect1info>
            <risinfo>
               <booktitle>How Can Nurses Survive Bullying Environments?</booktitle>
               <isbn>2320978303186</isbn>
