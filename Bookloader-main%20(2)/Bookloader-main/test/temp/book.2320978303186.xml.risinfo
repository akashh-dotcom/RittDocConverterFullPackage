               <chaptertitle>9. Simplifying Life</chaptertitle>
               <authorgroup>
                  <author>
                     <personname>
                        <firstname>Cheryl</firstname>
                        <surname>Green</surname>
                     </personname>
                  </author>
               </authorgroup>
               <publisher>
                  <publishername>Springer Nature Switzerland</publishername>
               </publisher>
               <pubdate>2025</pubdate>
            </risinfo>
            <primaryauthor>
               <personname>
                  <firstname>Cheryl</firstname>
                  <surname>Green</surname>
               </personname>
            </primaryauthor>
         </sect1info>
         <title>References</title>
         <para/>
