      <title>2. The Purnell Model for Cultural Competence</title>
      <sect1 id="ch0002s0004">
         <sect1info>
            <risinfo>
               <booktitle>Handbook for Culturally Competent Care</booktitle>
               <isbn>1316139783031</isbn>
