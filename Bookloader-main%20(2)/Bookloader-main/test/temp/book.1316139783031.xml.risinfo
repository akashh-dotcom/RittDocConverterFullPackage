            </primaryauthor>
         </sect1info>
         <title>22. People of Italian Heritage</title>
         <para role="ChapterCopyright">© The Author(s), under exclusive license to Springer Nature Switzerland AG 2024</para>
         <para role="ContextInformationAuthorEditorNames">E. A. Fenkl, L. D. Purnell<emphasis role="CollaboratorDesignation"> (eds.)</emphasis>
         </para>
         <para role="ContextInformationBookTitles">
            <emphasis role="BookTitle">Handbook for Culturally Competent Care</emphasis>
         </para>
         <para role="ChapterDOI">
            <ulink url="https://doi.org/10.1007/978-3-031-70492-5_22">https://doi.org/10.1007/978-3-031-70492-5_22</ulink>
         </para>
         <para role="AuthorGroup">
            <emphasis role="Author">
               <emphasis role="AuthorName">Alessandro Stievano</emphasis>
               <superscript>
                  <link linkend="ch0022">1</link>
               </superscript>, </emphasis>
            <emphasis role="Author">
               <emphasis role="AuthorName">Rosario Caruso</emphasis>
               <superscript>
                  <link linkend="ch0022">2</link>
               </superscript> and </emphasis>
            <emphasis role="Author">
               <emphasis role="AuthorName">Gennaro Rocco</emphasis>
               <superscript>
                  <link linkend="ch0022">1</link>
               </superscript>
            </emphasis>
         </para>
         <para role="AffiliationText">Centre of Excellence for Nursing Scholarship, Opi Rome, Rome, Italy</para>
         <para role="AffiliationText">Department of Biomedical Sciences for Health, University of Milan, Milan, Italy</para>
