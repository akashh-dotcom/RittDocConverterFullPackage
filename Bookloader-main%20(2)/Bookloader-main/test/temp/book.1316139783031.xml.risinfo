               <personname>
                  <firstname>Eric A.</firstname>
                  <surname>Fenkl</surname>
               </personname>
            </primaryauthor>
         </sect1info>
         <title>
            <emphasis role="HeadingNumber">14.2 </emphasis> Reflective Exercises</title>
         <orderedlist continuation="restarts" inheritnum="ignore">
            <listitem role="ListItem">
               <para>Distinguish German communication practices between family and outsiders.</para>
            </listitem>
            <listitem role="ListItem">
               <para>What protocol does Germans expect with a “closed door”?</para>
            </listitem>
            <listitem role="ListItem">
               <para>Describe taboo behaviors for German adolescents.</para>
            </listitem>
            <listitem role="ListItem">
               <para>Name and describe at least three genetic diseases common among Germans.</para>
            </listitem>
            <listitem role="ListItem">
               <para>What are the primary foods a German might use while recuperating from and illness?</para>
            </listitem>
            <listitem role="ListItem">
               <para>Describe some prescriptive and restrictive German postpartum practices.</para>
            </listitem>
            <listitem role="ListItem">
               <para>What might you do to encourage a stoic German to accept pain medication?</para>
            </listitem>
            <listitem role="ListItem">
               <para>How is mental illness perceived by Germans?</para>
            </listitem>
            <listitem role="ListItem">
               <para>Identify at least three common folk remedies commonly used by Germans.</para>
            </listitem>
            <listitem role="ListItem">
               <para>Describe a traditional German funeral.</para>
            </listitem>
         </orderedlist>
      </sect1>
