   <chapter id="ch0014" label="14">
      <title>14. People of German Heritage</title>
      <sect1 id="ch0014s0004">
         <sect1info>
            <risinfo>
               <booktitle>Handbook for Culturally Competent Care</booktitle>
               <isbn>1316139783031</isbn>
               <chapternumber>14</chapternumber>
               <chapterid>ch0014</chapterid>
               <chaptertitle>14. People of German Heritage</chaptertitle>
               <authorgroup>
                  <author>
                     <personname>
                        <firstname>Eric A.</firstname>
                        <surname>Fenkl</surname>
                     </personname>
                  </author>
                  <author>
                     <personname>
                        <firstname>Larry D.</firstname>
                        <surname>Purnell</surname>
                     </personname>
                  </author>
               </authorgroup>
               <publisher>
                  <publishername>Springer International Publishing</publishername>
               </publisher>
               <pubdate>2024</pubdate>
            </risinfo>
