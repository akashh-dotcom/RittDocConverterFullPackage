                        <entry>
                           <para role="SimplePara">Nasopharyngeal cancer</para>
                        </entry>
                        <entry>
                           <para role="SimplePara">Environment, lifestyle</para>
                        </entry>
                     </row>
                     <row>
                        <entry>
                           <para role="SimplePara">Lactase deficiency</para>
                        </entry>
                        <entry>
                           <para role="SimplePara">Genetic</para>
                        </entry>
                     </row>
                     <row>
                        <entry>
                           <para role="SimplePara">Leprosy</para>
                        </entry>
                        <entry>
                           <para role="SimplePara">Genetic</para>
                        </entry>
                     </row>
