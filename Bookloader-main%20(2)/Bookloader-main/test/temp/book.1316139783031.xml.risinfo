                           <para role="SimplePara">Causes</para>
                        </entry>
                     </row>
                     <row>
                        <entry>
                           <para role="SimplePara">Alcoholism</para>
                        </entry>
                        <entry>
                           <para role="SimplePara">Genetic, environment, lifestyle</para>
                        </entry>
                     </row>
                     <row>
                        <entry>
                           <para role="SimplePara">Depression</para>
                        </entry>
                        <entry>
                           <para role="SimplePara">Environment, lifestyle</para>
                        </entry>
                     </row>
                     <row>
                        <entry>
                           <para role="SimplePara">Gastrointestinal disorders</para>
                        </entry>
