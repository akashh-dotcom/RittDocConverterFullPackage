   <chapter id="ch0010" label="10">
      <title>10. People of Chinese Heritage</title>
      <sect1 id="ch0010s0004">
         <sect1info>
            <risinfo>
               <booktitle>Handbook for Culturally Competent Care</booktitle>
               <isbn>1316139783031</isbn>
