            <ulink url="https://doi.org/10.1007/978-3-031-70492-5_5">https://doi.org/10.1007/978-3-031-70492-5_5</ulink>
         </para>
         <para role="AuthorGroup">
            <emphasis role="Author">
               <emphasis role="AuthorName">Kathy Prue-Owens</emphasis>
               <superscript>
                  <link linkend="ch0005">1</link>
               </superscript>
            </emphasis>
         </para>
