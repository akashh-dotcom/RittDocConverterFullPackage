            </bibliomixed>
            <bibliomixed id="ch0016s0003bib07">Weller SC, Ruebush TK, Klein RR (1991) An epidemiological description of folk illnesses: a study of empacho in Guatemala. Med Anthropol 13(1–2):19–31<bibliomisc>
                  <ulink url="https://doi.org/10.1080/01459740.1991.9966039">https://doi.org/10.1080/01459740.1991.9966039</ulink>
               </bibliomisc>
               <bibliomisc>
                  <ulink url="http://www.ncbi.nlm.nih.gov/entrez/query.fcgi?cmd=Retrieve&amp;db=PubMed&amp;dopt=Abstract&amp;list_uids=1881298">PubMed</ulink>
