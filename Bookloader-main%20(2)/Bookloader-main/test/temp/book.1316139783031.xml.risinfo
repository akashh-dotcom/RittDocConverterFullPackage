   <chapter id="ch0032" label="32">
      <title>32. People of Thai Heritage</title>
      <sect1 id="ch0032s0004">
         <sect1info>
            <risinfo>
               <booktitle>Handbook for Culturally Competent Care</booktitle>
               <isbn>1316139783031</isbn>
               <chapternumber>32</chapternumber>
