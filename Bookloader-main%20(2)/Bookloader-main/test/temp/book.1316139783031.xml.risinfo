         </sect1info>
         <title>Bibliography</title>
         <para/>
         <bibliography id="ch0017s0003bib0001">
            <bibliomixed id="ch0017s0003bib01">CIA (2024) World Factbook: Haiti. <bibliomisc>
                  <ulink url="https://www.cia.gov/the-world-factbook/countries/haiti/">
                     <emphasis role="RefSource">https://www.cia.gov/the-world-factbook/countries/haiti/</emphasis>
                  </ulink>
               </bibliomisc>
            </bibliomixed>
            <bibliomixed id="ch0017s0003bib02">Cultural Competency and Haitian Immigrants: Death rituals (2003). <bibliomisc>
                  <ulink url="https://nj.gov/humanservices/emergency/HaitiCultural_ClinicalCarePresentation.pdf">
                     <emphasis role="RefSource">https://nj.gov/humanservices/emergency/Haiti Cultural_Clinical Care Presentation.pdf</emphasis>
                  </ulink>
               </bibliomisc>
            </bibliomixed>
            <bibliomixed id="ch0017s0003bib03">Dain B, Batalova (2023). Haitian Immigrants in the United States. <bibliomisc>
                  <ulink url="https://www.migrationpolicy.org/article/haitian-immigrants-united-states#income-poverty">
                     <emphasis role="RefSource">https://www.migrationpolicy.org/article/haitian-immigrants-united-states#income-poverty</emphasis>
                  </ulink>
               </bibliomisc>
            </bibliomixed>
            <bibliomixed id="ch0017s0003bib04">Death and Funeral Rituals in the Haitian Culture (2013) Haiti Observer. <bibliomisc>
                  <ulink url="http://www.haitiobserver.com/blog/death-and-funeral-rituals-in-haitian-culture.html">
                     <emphasis role="RefSource">http://www.haitiobserver.com/blog/death-and-funeral-rituals-in-haitian-culture.html</emphasis>
                  </ulink>
               </bibliomisc>
