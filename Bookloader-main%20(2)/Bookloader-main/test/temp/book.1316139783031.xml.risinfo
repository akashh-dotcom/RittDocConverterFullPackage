   <chapter id="ch0026" label="26">
      <title>26. People of Korean Heritage</title>
      <sect1 id="ch0026s0004">
         <sect1info>
            <risinfo>
               <booktitle>Handbook for Culturally Competent Care</booktitle>
               <isbn>1316139783031</isbn>
