               <chapterid>ch0031</chapterid>
               <chaptertitle>31. People of Somali Heritage</chaptertitle>
               <authorgroup>
                  <author>
                     <personname>
                        <firstname>Eric A.</firstname>
                        <surname>Fenkl</surname>
                     </personname>
                  </author>
                  <author>
