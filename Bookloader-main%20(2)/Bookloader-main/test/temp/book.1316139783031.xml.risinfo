            <emphasis role="BookTitle">Handbook for Culturally Competent Care</emphasis>
         </para>
         <para role="ChapterDOI">
            <ulink url="https://doi.org/10.1007/978-3-031-70492-5_8">https://doi.org/10.1007/978-3-031-70492-5_8</ulink>
         </para>
         <para role="AuthorGroup">
            <emphasis role="Author">
               <emphasis role="AuthorName">Suha Ballout</emphasis>
               <superscript>
                  <link linkend="ch0008">1</link>
               </superscript>
            </emphasis>
         </para>
         <para role="AffiliationText">Manning College of Nursing and Health Sciences, University of Massachusetts, Boston, MA, USA</para>
         <para role="Contact">
            <emphasis role="AuthorName">Suha Ballout</emphasis><?lb?>
            <emphasis role="ContactType">Email: </emphasis>
            <ulink url="mailto:Suha.Ballout@umb.edu">Suha.Ballout@umb.edu</ulink>
         </para>
         <para role="keywords">Arab heritage, Communities, Legacy, Identity, Cultural responses</para>
      </sect1>
      <sect1 id="ch0008s0001" role="Heading">
         <sect1info>
            <risinfo>
               <booktitle>Handbook for Culturally Competent Care</booktitle>
               <isbn>1316139783031</isbn>
               <chapternumber>8</chapternumber>
               <chapterid>ch0008</chapterid>
               <chaptertitle>8. People of Arab Heritage</chaptertitle>
               <authorgroup>
                  <author>
                     <personname>
                        <firstname>Eric A.</firstname>
                        <surname>Fenkl</surname>
                     </personname>
                  </author>
                  <author>
                     <personname>
                        <firstname>Larry D.</firstname>
                        <surname>Purnell</surname>
                     </personname>
                  </author>
               </authorgroup>
               <publisher>
                  <publishername>Springer International Publishing</publishername>
               </publisher>
               <pubdate>2024</pubdate>
            </risinfo>
