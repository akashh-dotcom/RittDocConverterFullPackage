         </sect1info>
         <title>Bibliography</title>
         <para/>
         <bibliography id="ch0016s0003bib0001">
            <bibliomixed id="ch0016s0003bib01">Callister LC, Vega R (1998) Giving birth: Guatemalan women’s voices. J Obstet Gynecol Neonatal Nurs 27(3):289–295<bibliomisc>
                  <ulink url="https://doi.org/10.1111/j.1552-6909.1998.tb02651.x">https://doi.org/10.1111/j.1552-6909.1998.tb02651.x</ulink>
               </bibliomisc>
               <bibliomisc>
                  <ulink url="http://www.ncbi.nlm.nih.gov/entrez/query.fcgi?cmd=Retrieve&amp;db=PubMed&amp;dopt=Abstract&amp;list_uids=9620821">PubMed</ulink>
               </bibliomisc>
            </bibliomixed>
            <bibliomixed id="ch0016s0003bib02">Cerón A, Ruano AL, Sánchez S, Chew AS, Díaz D, Hernández A, Flores W (2016) Abuse and discrimination towards indigenous people in public health care facilities: experiences from rural Guatemala. Int J Equity Health 15:77. PMID: 27177690; PMCID: PMC4866428<bibliomisc>
                  <ulink url="https://doi.org/10.1186/s12939-016-0367-z">https://doi.org/10.1186/s12939-016-0367-z</ulink>
               </bibliomisc>
               <bibliomisc>
                  <ulink url="https://doi.org/10.1186/s12939-016-0367-z">https://doi.org/10.1186/s12939-016-0367-z</ulink>
               </bibliomisc>
               <bibliomisc>
                  <ulink url="http://www.ncbi.nlm.nih.gov/entrez/query.fcgi?cmd=Retrieve&amp;db=PubMed&amp;dopt=Abstract&amp;list_uids=27177690">PubMed</ulink>
               </bibliomisc>
               <bibliomisc>
                  <ulink url="http://www.ncbi.nlm.nih.gov/pmc/articles/PMC4866428">PubMedCentral</ulink>
               </bibliomisc>
            </bibliomixed>
            <bibliomixed id="ch0016s0003bib03">CIA world factbook: Guatemala (2023). <bibliomisc>
                  <ulink url="https://www.cia.gov/the-world-factbook/countries/guatemala/">
                     <emphasis role="RefSource">https://www.cia.gov/the-world-factbook/countries/guatemala/</emphasis>
                  </ulink>
               </bibliomisc>
            </bibliomixed>
            <bibliomixed id="ch0016s0003bib04">Ellis T, Purnell L (2013) People of Guatemalan heritage. In: Purnell L (ed) Transcultural health care: a culturally competent approach. F. A Davis, Philadelphia</bibliomixed>
            <bibliomixed id="ch0016s0003bib05">Ellis TA, Purnell LD (2021) People of Guatemalan heritage. In: Textbook for transcultural health care: a population approach: cultural competence concepts in nursing care. Springer, Cham, pp 445–467<bibliomisc>
                  <ulink url="https://doi.org/10.1007/978-3-030-51399-3_17">https://doi.org/10.1007/978-3-030-51399-3_17</ulink>
               </bibliomisc>
            </bibliomixed>
            <bibliomixed id="ch0016s0003bib06">Johanson L (2016) Caring for the vulnerable: an exploration of Guatemalan healthcare issues. J Christ Nurs 33(1):44–49<bibliomisc>
                  <ulink url="https://doi.org/10.1097/CNJ.0000000000000232">https://doi.org/10.1097/CNJ.0000000000000232</ulink>
               </bibliomisc>
