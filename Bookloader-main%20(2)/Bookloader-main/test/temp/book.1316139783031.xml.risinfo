   <chapter id="ch0006" label="6">
      <title>6. The Amish</title>
      <sect1 id="ch0006s0004">
         <sect1info>
            <risinfo>
               <booktitle>Handbook for Culturally Competent Care</booktitle>
               <isbn>1316139783031</isbn>
