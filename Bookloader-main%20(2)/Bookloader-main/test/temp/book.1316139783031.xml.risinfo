                     </entry>
                  </row>
               </tbody>
            </tgroup>
         </table>
         <table id="ch0023s0001ta02">
            <title>
               <emphasis role="CaptionNumber">Table 23.2</emphasis> Division of counties and Parish</title>
            <tgroup cols="3">
               <colspec colname="c1" colnum="1"/>
               <colspec colname="c2" colnum="2"/>
               <colspec colname="c3" colnum="3"/>
               <tbody>
                  <row>
                     <entry>
                        <para role="SimplePara">Cornwall</para>
                     </entry>
                     <entry>
                        <para role="SimplePara">Middlesex</para>
                     </entry>
                     <entry>
                        <para role="SimplePara">Surrey</para>
                     </entry>
                  </row>
                  <row>
                     <entry>
                        <para role="SimplePara">St. Elizabeth</para>
                     </entry>
                     <entry>
                        <para role="SimplePara">St. Catherine</para>
                     </entry>
                     <entry>
                        <para role="SimplePara">Kingston and St. Andrew</para>
                     </entry>
                  </row>
                  <row>
                     <entry>
                        <para role="SimplePara">Trelawny</para>
                     </entry>
