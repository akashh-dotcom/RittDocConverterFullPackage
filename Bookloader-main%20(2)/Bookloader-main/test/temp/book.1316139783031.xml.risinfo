      </sect1>
   </chapter>
   <chapter id="ch0017" label="17">
      <title>17. People of Haitian Heritage</title>
      <sect1 id="ch0017s0004">
         <sect1info>
            <risinfo>
               <booktitle>Handbook for Culturally Competent Care</booktitle>
               <isbn>1316139783031</isbn>
               <chapternumber>17</chapternumber>
