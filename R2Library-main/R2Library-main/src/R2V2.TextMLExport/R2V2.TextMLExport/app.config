<?xml version="1.0"?>
<configuration>
	<configSections>
		<sectionGroup name="applicationSettings" type="System.Configuration.ApplicationSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089">
			<section name="R2V2.TextMLExport.Setting" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false"/>
		</sectionGroup>
		<section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, 
    log4net"/>
	</configSections>
	<connectionStrings>
  <add name="R2V2.TextMLExport.Setting.R2UtilitiesDatabaseConnection" connectionString="Server=10.0.0.32;Database=R2Utilities;User ID=R2UtilitiesUser;Password=R2User2012;Trusted_Connection=False"/>
  <add name="R2V2.TextMLExport.Setting.R2DatabaseConnection" connectionString="Server=10.0.0.32;Database=RIT001_2012-03-21;User ID=R2WebUser;Password=Web2012;Trusted_Connection=False"/>
 </connectionStrings>
 <applicationSettings>
		<R2V2.TextMLExport.Setting>
   <setting name="TextmlServer" serializeAs="String">
    <value>10.0.0.67</value>
   </setting>
   <setting name="OutputDirectory" serializeAs="String">
    <value>E:\R2v2\Content\xml3</value>
   </setting>
   <setting name="TextmlDocBase" serializeAs="String">
    <value>RIS Document Base</value>
   </setting>
   <setting name="BatchSize" serializeAs="String">
    <value>5</value>
   </setting>
  </R2V2.TextMLExport.Setting>
	</applicationSettings>
	<startup>
		
	<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.0"/></startup>
	<log4net debug="false">
		<appender name="LogFileAppender" type="log4net.Appender.RollingFileAppender">
			<param name="File" value="E:\Log4NetLogs\R2v2.TextMLExport\R2v2.TextMLExport.log"/>
			<param name="AppendToFile" value="false"/>
			<rollingStyle value="Size"/>
			<maxSizeRollBackups value="50"/>
			<maximumFileSize value="50MB"/>
			<layout type="log4net.Layout.PatternLayout,log4net">
				<param name="ConversionPattern" value="%date [%thread] %-5level %logger.%method - %message%newline"/>
			</layout>
		</appender>
		<appender name="ConsoleAppender" type="log4net.Appender.ConsoleAppender, log4net">
			<layout type="log4net.Layout.PatternLayout,log4net">
				<param name="ConversionPattern" value="%message%newline"/>
			</layout>
			<param name="Threshold" value="INFO"/>
			<!--<filter type="log4net.Filter.LoggerMatchFilter">
				<acceptOnMatch value="true" />
				<LoggerToMatch value="R2Utilities" />
			</filter>
			<filter type="log4net.Filter.DenyAllFilter" />-->
		</appender>
		<root>
			<priority value="ALL"/>
			<appender-ref ref="LogFileAppender"/>
			<appender-ref ref="ConsoleAppender"/>
		</root>
	</log4net>
</configuration>
