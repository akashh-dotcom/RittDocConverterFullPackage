<RittenhouseWebLoader>
	<EmailConfigurations>
		<!-- Email config for in task emails, example: reports -->
		<EmailConfiguration type="Task" send="true">
			<ToAddresses>
				<!--<EmailAddress>kenhaberle@technotects.com</EmailAddress>-->
				<EmailAddress>ScottScheider@technotects.com</EmailAddress>
			</ToAddresses>
		</EmailConfiguration>
		<!-- Email config end of task emails on success -->
		<EmailConfiguration type="Success" send="true">
			<ToAddresses>
				<!--<EmailAddress>kenhaberle@technotects.com</EmailAddress>-->
				<EmailAddress>ScottScheider@technotects.com</EmailAddress>
			</ToAddresses>
		</EmailConfiguration>
		<!-- Email config end of task emails on error -->
		<EmailConfiguration type="Error" send="true">
			<ToAddresses>
				<!--<EmailAddress>kenhaberle@technotects.com</EmailAddress>-->
				<EmailAddress>ScottScheider@technotects.com</EmailAddress>
			</ToAddresses>
		</EmailConfiguration>
	</EmailConfigurations>
</RittenhouseWebLoader>
