@model R2V2.Web.Models.IR2V2Model
           
<!doctype html>
<html class="no-js" lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
   
    <style type="text/css">
        [[CSS]]
    </style>
</head>
<body class="email">
    <div id="container" class="clearfix">
        [[From]]
        [[Comment]]
        
        @RenderBody()
            
        <p class="footer">&copy; @Model.Footer.CopyrightText | <a href="@Url.Action("PrivacyPolicy", "Home", new { Area = "" }, "http")">Privacy Policy</a> | <a href="@Url.Action("CopyrightPolicy", "Home", new { Area = "" }, "http")">Copyright Policy</a></p>
    </div>
</body>
</html>