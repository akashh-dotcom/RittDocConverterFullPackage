@model R2V2.Web.Models.Cms.CmsHtml
@{
    ViewBag.Title = @Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (!string.IsNullOrWhiteSpace(Model.Html))
{
    <div class="onecol contentcontainer">
        <div id="content" class="content" role="main">
            <div>@Html.Raw(Model.Html)</div>
        </div>
    </div>
}
else
{
    @*<div class="onecol contentcontainer">
        <div id="content" class="content" role="main">
            <div>@Html.Raw(Model.FormHeader)</div>*@
            @Html.Partial("_ContactForm")
        @*</div>
    </div>*@
}

