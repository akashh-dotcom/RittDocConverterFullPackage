@using R2V2.Extensions
@model R2V2.Web.Models.Error.NotFoundViewModel
@{
    ViewBag.Title = "Not Found";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="onecol contentcontainer">
    <div class="hero" role="main">
        <h1>Sorry, you tried to access a page on this website that could not be found.</h1>
        
        <ul class="list-errors">
            @if(Model.ErrorId.IsNotEmpty()){
                <li><strong>Request Id:</strong> @Model.ErrorId</li>
            }
            <li><strong>Time:</strong> @DateTime.Now.ToString()</li>
            <li><strong>Reported Error Path:</strong> @Model.AspxErrorPath</li>
        </ul>
    </div>
</div>