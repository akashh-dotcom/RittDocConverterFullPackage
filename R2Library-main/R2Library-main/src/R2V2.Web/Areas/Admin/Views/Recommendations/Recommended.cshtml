@model R2V2.Web.Areas.Admin.Models.Recommendations.RecommendationEdit
@{
	ViewBag.Title = "Recommend for Purchase";
	ViewBag.BodyCssClass = "admin";
	Layout = "~/Views/Shared/_LayoutModal.cshtml";
}

<div class="content collection-manage recommend">
    <div class="modal-header">
            @if (Model.Action == "delete")
            {
                <h1>Resource Recommended for Purchase Deleted</h1>
            }
            else if (Model.Action == "update")
            {
                <h1>Resource Recommended for Purchase Updated</h1>
            }
            else
            {
                <h1>Resource Recommended for Purchase Added</h1>
            }
        <a class="close" href="@Model.BackToListLink" data-dismiss="navigation">Close</a>
    </div>
            
    <div class="modal-body">
        <h2>@Model.InstitutionResource.Title</h2>
        <ul>
            <li>@Html.LabelFor(modelItem => Model.InstitutionResource.Isbn10) @Model.InstitutionResource.Isbn</li>
            <li>@Html.LabelFor(modelItem => Model.InstitutionResource.Authors) @Model.InstitutionResource.Authors</li>
            <li>@Html.LabelFor(modelItem => Model.InstitutionResource.PublisherName) @Model.InstitutionResource.PublisherName</li>
        </ul>

		<table>
			<tbody>
				<tr>
                    <th><strong>@Html.LabelFor(model => model.Recommended.Notes)</strong></th>
					<td class="field">@Html.DisplayFor(model => model.Recommended.Notes)</td>
				</tr>
			</tbody>
		</table>
		<br />
        @Html.Hidden("RecommendForPurchase", "yes")
		@Html.Partial("../CollectionManagement/_HiddenQueryFields", Model.ResourceQuery)
		<div class="actions">
			<a href="@Model.ViewMyRecommendationsLink" class="btn btn-medium" data-dismiss="navigation"><span>View My Recommendations</span></a>
			@if (Model.ReviewId > 0)
			{
				<a href="@Model.BackToListLink" class="btn btn-medium" data-dismiss="navigation"><span>Back to Review List</span></a>
			}
			else
			{
				<a href="@Model.BackToListLink" class="btn btn-medium" data-dismiss="navigation"><span>Back to Resource List</span></a>
			}
		</div>
    </div>
</div>

@section JsDocumentReady
{
    new R2V2.Admin.IFrameModal({
        parent: window.parent,
        $dismiss: $('a[data-dismiss="navigation"]')
    });
}