@using R2V2.Web.Areas.Admin.Models
@model R2V2.Web.Areas.Admin.Models.CollectionManagement.InstitutionResources
@{
	ViewBag.Title = "Marc Export";
	ViewBag.BodyCssClass = "admin";
	Layout = "~/Views/Shared/_LayoutModal.cshtml";
}

<div class="content collection-manage">
    <div class="modal-header">
        <h1>Export Marc Records</h1>
        <a class="close" data-dismiss="modal" href="#">Close</a>
    </div>
            
    <div class="modal-body">
		<div id="bulk-add-area">
            <h3>The following resources are available for Marc Export:</h3>
            <ul>		
                @foreach (var resource in Model.InstitutionResourcesList)
                {
                    <li>@resource.Title, ISBN: @resource.Isbn13 at @Html.DisplayFor(model => resource.DiscountPrice)</li>
                }
            </ul>
            <p><strong>Resource Count: @Html.Raw(Model.InstitutionResourcesList.Count().ToString())</strong></p>

        </div>
		<div class="actions">
		    <a class="cancel" data-dismiss="modal" href="#">Cancel</a>
            <a class="btn btn-medium" data-dismiss="modal" target="_blank" data-toggle="window" href="@Url.Action("CollectionManagementList", "MarcExport", Model.CollectionManagementQuery.ToMarcRouteValues(false, false) )" data-specs="location=1,status=1,scrollbars=1,height=300,width=475"><span>Export to Marc</span></a>
		    <a class="btn btn-medium" data-dismiss="modal" target="_blank" data-toggle="window" href="@Url.Action("CollectionManagementList", "MarcExport", Model.CollectionManagementQuery.ToMarcRouteValues(false, true) )" data-specs="location=1,status=1,scrollbars=1,height=300,width=475"><span>Export to Marc Delete</span></a>
            
            @*<p><strong><a href="@Url.Action("Resource", "MarcExport", new { InstitutionId = 0, Model.Isbn })" target="_blank" data-toggle="window" data-specs="location=1,status=1,scrollbars=1,height=200,width=300">Marc Export</a></strong></p>*@
		</div>
    </div>
</div>

@section JsDocumentReady
{
    new R2V2.Admin.IFrameModal({ 
        $dismiss: $('a[data-dismiss="modal"]'), 
        parent: window.parent 
    });
}