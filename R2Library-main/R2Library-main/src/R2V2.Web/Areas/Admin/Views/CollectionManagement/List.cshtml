@using R2V2.Web.Areas.Admin.Models
@model R2V2.Web.Areas.Admin.Models.CollectionManagement.InstitutionResources
@{
	ViewBag.Title = "Collection Management";
	ViewBag.BodyCssClass = "admin";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_Tabs")

@Html.Partial("ActionsMenus/_ActionsMenu", Model.ActionsMenu)

<div class="clearfix twocol-with-subnav contentcontainer">
    <div id="content" class="content" role="main">
        <h1>@Html.Raw(Model.PageTitle)</h1>
        
        @using (Html.BeginForm())
		{
            <div class="display-per-page">
                <p class="screenreader">Choose the number of titles to display per page.</p>
                @Html.DropDownListFor(x => x.CollectionManagementQuery.PageSize, Model.PageSizeSelectList, new { onchange = "this.form.submit();" })
                @Html.LabelFor(x => x.PageSizeSelectList)
            </div>
            @Html.HiddenFor(x => x.CollectionManagementQuery.Query)
            @Html.HiddenFor(x => x.CollectionManagementQuery.ResourceStatus)
            @Html.HiddenFor(x => x.CollectionManagementQuery.ResourceFilterType)
            @Html.HiddenFor(x => x.CollectionManagementQuery.SortDirection)
            @Html.Hidden("page", "1")
            @Html.HiddenFor(x => x.CollectionManagementQuery.PracticeAreaFilter)
            @Html.HiddenFor(x => x.CollectionManagementQuery.SpecialtyFilter)
			@Html.HiddenFor(x => x.CollectionManagementQuery.SortBy)
            @Html.HiddenFor(x => x.CollectionManagementQuery.IncludePdaResources)            
            @Html.HiddenFor(x => x.CollectionManagementQuery.IncludePdaHistory)
            @Html.HiddenFor(x => x.CollectionManagementQuery.CollectionListFilter)
            @Html.HiddenFor(x => x.CollectionManagementQuery.IncludeFreeResources)
            @Html.HiddenFor(x => x.CollectionManagementQuery.CollectionFilter)
            @Html.HiddenFor(x => x.CollectionManagementQuery.IncludeSpecialDiscounts)
            @Html.HiddenFor(x => x.CollectionManagementQuery.PurchasedOnly)
            @Html.HiddenFor(x => x.CollectionManagementQuery.RecommendationsOnly)

            @Html.HiddenFor(x => x.CollectionManagementQuery.ResourceListType)
            @Html.HiddenFor(x => x.CollectionManagementQuery.DateRangeStart)
            @Html.HiddenFor(x => x.CollectionManagementQuery.DateRangeEnd)
            @Html.HiddenFor(x => x.CollectionManagementQuery.TurnawayStartDate)
            @Html.HiddenFor(x=> x.CollectionManagementQuery.PublisherId)
		}
        
        @Html.Partial("_InstitutionInfo")

        @if (Model.Publisher != null)
        {
            @Html.Partial("_Publisher", Model.Publisher)
        }
        
        @if (!string.IsNullOrWhiteSpace(Model.PageDescription))
        {
            <div style="font-family: arial; font-size: 16px; font-style: normal; background-color: white" class="richText">@Html.Raw(Model.PageDescription)</div>
        }

        @if (Model.PageLinks.Count() > 1)
        {
            <div class="nav-section-wrapper">
                <div class="clearfix nav-section" data-implement="fixed">
                    <div class="previous">
                        @if (Model.PreviousLink.Active)
                        {
                            <a href="@Model.FirstLink.Href">&lt; @Model.FirstLink.Text</a>
                            <a href="@Model.PreviousLink.Href">&lt;&lt; @Model.PreviousLink.Text</a>
                        }
                    </div>

                    <div class="next">
                        @if (Model.NextLink.Active)
                        {
                            <a href="@Model.NextLink.Href">@Model.NextLink.Text &gt;&gt;</a>
                            <a href="@Model.LastLink.Href">@Model.LastLink.Text &gt;</a>
                        }
                    </div>
                
                    <ul class="nav-number nav-content">
                        <li><strong>Jump to page:</strong></li>
                        @foreach (var link in Model.PageLinks)
                        {
                            if (link.Active)
                            {
                                <li@(StyleHelpers.AddSelectedState(link.Selected))><a href="@link.Href"><span>@link.Text</span></a></li>
                            }
                            else
                            {
                                <li><span>@link.Text</span></li>
                            }
                        }
                    </ul>
                </div>
            </div>
        }
        
        
        <div class="alertbox">
            @if (Model.TotalCount != 0)
            {
                <h3>Displaying results <strong>@string.Format("{0:#,##0} - {1:#,##0}",  Model.ResultsFirstItem, Model.ResultsLastItem)</strong> out of <strong>@string.Format("{0:#,##0}", Model.TotalCount)</strong>.</h3>
            }
            
            @if (!string.IsNullOrWhiteSpace(Model.SelectedFilters) || (!Model.CollectionManagementQuery.DefaultQuery && Model.ActionsMenu != null))
            {
                <div class="criteria clearfix">
                    <p>Search criteria:</p>
                    @if (!string.IsNullOrWhiteSpace(Model.SelectedFilters))
                    {
                        <ul>
                            @Html.Raw(Model.SelectedFilters)
                        </ul>
                    }
                    @if (!Model.CollectionManagementQuery.DefaultQuery && Model.ActionsMenu != null)
                    {
                        @*<p><a href="@Url.Action("List", new { Model.CollectionManagementQuery.PurchasedOnly, Model.CollectionManagementQuery.ResourceListType, Model.CollectionManagementQuery.DateRangeStart, Model.CollectionManagementQuery.DateRangeEnd, Model.InstitutionId })">Clear Results</a> or <a href="#sort-and-filter" data-toggle="link">Add More Criteria</a>.</p>*@
                        <p><a href="@Url.Action("List", Model.CollectionManagementQuery.ToDefaultQuery())">Clear Results</a> or <a href="#sort-and-filter" data-toggle="link">Add More Criteria</a>.</p>
                    }    
                </div>
            }
        </div>
@if (Model.InstitutionResourcesList != null && Model.InstitutionResourcesList.Any())
{
            <div class="group-actions-wrapper">
                <div class="clearfix group-actions">
                    <ul class="actions" id="select-actions">
                        @if (Model.IsExpertReviewer)
                        {
							<li><a href="@Url.Action("BulkRecommend", "Recommendations", Model.CollectionManagementQuery.ToRouteValues())" class="btn-mini btn-link btn-addSelected disabled" data-implement="modal"><span>Add recommendations for selected</span></a></li>
                        }
                        else
                        {
                            <li><a href="@Url.Action("BulkAddToCart", "Cart", Model.GetQueryWithParentPageTitle(Model.PageTitle))" class="btn-mini btn-link btn-addSelected disabled" data-implement="modal"><span>Add selected to cart</span></a></li>
                            if (Model.DisplayBulkPdaOption)
                            {
                                <li><a href="@Url.Action("BulkAddPda", "Pda", Model.CollectionManagementQuery.ToRouteValues())" class="btn-mini btn-link btn-addSelected disabled" data-implement="modal"><span>Add selected as PDA</span></a></li>
                            }
                            if (Model.CollectionManagementQuery.IncludePdaResources)
                            {
                                <li><a href="@Url.Action("BulkDeletePda", "Pda", Model.CollectionManagementQuery.ToRouteValues())" class="btn-mini btn-link btn-addSelected disabled" data-implement="modal"><span>Delete selected from PDA</span></a></li>
                            }
                            <li><a href="@Url.Action("CollectionManagement", "MarcExport", Model.CollectionManagementQuery.ToRouteValues())" class="btn-mini btn-link btn-addSelected disabled" data-implement="modal" ><span>Export selected to MARC</span></a></li>
                        }
                    </ul>
                </div>
            </div>
        }
        
        @Html.Partial("_List", Model)
    </div>
    <div id="testing123"></div>
    @Html.Partial("_LeftNav", Model)
</div>

@section JsDocumentReady
{
    
    new R2V2.Admin.ActionsMenu({ $container: $('.actions-menu') });
    new R2V2.Admin.AddToCollection({ $parent: $('#container'), trigger: '.btn-add' });
    new R2V2.Admin.PdaCollection({ $parent: $('#container'), triggers: ['.btn-addPda', '.btn-deletePda','.btn-recommend'] });
    new R2V2.Admin.EditLicenseCount({ $parent: $('#container'), trigger: '.btn-edit' });
    new R2V2.Admin.ScrollTo({ location: location.hash });
    new R2V2.Admin.SelectedItems({ $container: $('#ebooks'), trigger: '.item-select' });
    new R2V2.Admin.AddSelectedItems({ $parent: $('#container'), trigger: '.btn-addSelected' });
    new R2V2.Admin.LeftNav({ $container: $('.admin-left-nav') });
    
    $(document).ready(function() {
        $("[id^=click-]").on("click",function(event){
            var selected = event.target.id;
            var isbn = selected.substring(6, selected.lastIndexOf("-"));
            var index = selected.substring(7+isbn.length, selected.length);

            $("#testing123").load(
                '/CollectionManagement/ResourceClick'
                , {isbn: isbn, index: index, pageTitle: '@Model.PageTitle'}
                , function(){
                    $("#click-" + isbn).off( "click" );
            });
        });
    });
}