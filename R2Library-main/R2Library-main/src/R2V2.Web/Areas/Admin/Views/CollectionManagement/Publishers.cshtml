@model R2V2.Web.Areas.Admin.Models.CollectionManagement.ActivePublisherList

@{
    ViewBag.Title = "Publishers";
    ViewBag.BodyCssClass = "admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_Tabs")

@Html.Partial("ActionsMenus/_ActionsMenu", Model.ActionsMenu)

<div class="clearfix twocol-with-subnav contentcontainer">
    <div id="content" class="content" role="main">
        <h1>Purchase by Publisher</h1>
        
        
        @foreach (var activePublisher in Model.Publishers)
        {
            <div>
                @Html.ActionLink(activePublisher.Name, "List", Model.ToRouteValues(activePublisher.Id)) (@Html.DisplayFor(x=> activePublisher.ResourceCount))
            </div>
        }
    </div>
    @Html.Partial("_LeftNav", Model)
</div>

@section JsDocumentReady
{
    new R2V2.Admin.LeftNav({ $container: $('.admin-left-nav') });
}