@model R2V2.Web.Areas.Admin.Models.CollectionManagement.ActivePublisher

@*<div style="background-color: white; padding: 2%;">*@
<div class="alertbox richText">

    @if (!string.IsNullOrWhiteSpace(Model.ImageFileName))
    {
        <img src="@Model.ImageFileName" alt="@Model.Name" style="margin: auto;" />
    }
    else
    {
        if (string.IsNullOrWhiteSpace(Model.Description))
        {
            @Model.Name
        }

    }
    @Html.Raw(Model.Description)
    @*<br/>*@
</div>