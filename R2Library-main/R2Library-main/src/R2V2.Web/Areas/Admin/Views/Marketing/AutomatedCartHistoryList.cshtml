@model R2V2.Web.Areas.Admin.Models.Marketing.AutomatedCartHistoryModel

@{
	ViewBag.Title = "Automated Shopping Carts";
	ViewBag.BodyCssClass = "admin";
	Layout = "~/Views/Shared/_Layout.cshtml";
}


@Html.Partial("_Tabs")

@Html.Partial("ActionsMenus/_ActionsMenu", Model.ActionsMenu)

<div class="clearfix twocol-with-subnav contentcontainer">
	<div id="content" class="content" role="main">
		<h1>Automated Cart History</h1>
		@*<div id="report-filters" class="tablecontent" style="padding: 0 10px">
			Coming Soon.
		</div>*@
		<div class="tablecontent">
			<table class="list" id="table-for-select">
				<thead>
				<tr>
					<th>Cart Name</th>
					<th>Created Date</th>
					<th>Number of Institutions</th>
					<th>Processed</th>
					<th>All Processed</th>
				</tr>
				</thead>
				<tbody>
				@foreach (var item in Model.AutomatedCartHistories)
				{
					<tr>
						<td>
							<a href="@Url.Action("AutomatedCartHistory", new{ item.AutomatedCartId })">@item.CartName</a>
						</td>
						<td>@item.CreatedDate</td>
						<td>@item.InstitutionCount</td>
						<td>@item.ProcessedCount</td>
						<td>
							@if (item.WasProcessed)
							{
								<i class="fa fa-check" aria-hidden="true"></i>
							}
						</td>
					</tr>
				}
				</tbody>
			</table>
		</div>

	</div>
	@Html.Partial("_LeftNav", Model)
</div>

@section JsDocumentReady
{
    new R2V2.Admin.LeftNav({ $container: $('.admin-left-nav') });
}