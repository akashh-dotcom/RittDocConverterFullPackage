@model R2V2.Web.Areas.Admin.Models.InstitutionReferrer.InstitutionReferrerList
@{
    ViewBag.Title = "Manage Referers";
    ViewBag.BodyCssClass = "admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_Tabs")

@Html.Partial("ActionsMenus/_ActionsMenu", Model.ActionsMenu)

<div class="clearfix twocol-with-subnav contentcontainer">
    
    @Html.HiddenFor(x => x.InstitutionId)

    <div id="content" class="content" role="main">
        <h1>Manage Referrers</h1>
        
        @Html.Partial("_InstitutionInfo")

        <div class="group-actions-wrapper">
            <div class="clearfix group-actions" data-implement="fixed">
                <ul class="actions">
                    <li>
                        @if (Model.IsRittenhouseAdmin)
                        {
                            <a href="@Url.Action("Add", new { institutionId = Model.InstitutionId })" class="btn btn-medium"><span>Add Referrer</span></a>
                        }
                    
                    </li>
                </ul>
            </div>
        </div>
        @Html.Partial("_UrlReferrerInstructions")

            @if (Model.InstitutionReferrers != null && Model.InstitutionReferrers.Any())
            {
                <div class="tablecontent">
                    <table class="list">
                        <thead>
                            <tr>
                                <th colspan="2">Valid Referrers</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.InstitutionReferrers)
                            {
                                <tr>
                                    <td>@Html.DisplayFor(modelItem => item.ValidReferer)</td>
                                    @if (Model.IsRittenhouseAdmin)
                                    {
                                        <td class="actions">
                                            <a href="@Url.Action("Edit", new { institutionId = Model.InstitutionId, id = item.ValidReferrerId })" class="btn btn-medium"><span>Edit</span></a> 
                                            <a href="@Url.Action("Delete", new { institutionId = Model.InstitutionId, id = item.ValidReferrerId })" class="btn btn-medium"><span>Delete</span></a>
                                        </td>                                    
                                    }                                
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p><strong>No Referrers Available.</strong></p>
            }
        </div>

    @Html.Partial("_LeftNav", Model)
</div>

@section JsDocumentReady
{
    new R2V2.Admin.ActionsMenu({ $container: $('.actions-menu') });
    new R2V2.Admin.LeftNav({ $container: $('.admin-left-nav') });
}