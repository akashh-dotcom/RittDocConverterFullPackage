@model R2V2.Web.Areas.Admin.Models.SpecialCollectionManagement.ListModel

@{
    ViewBag.Title = "Special Collection Management";
    ViewBag.BodyCssClass = "admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_Tabs")

@Html.Partial("ActionsMenus/_ActionsMenu", Model.ActionsMenu)

<div class="fullcol contentcontainer">
    <div id="content" class="content" role="main">
        <h1>Special Collection Management</h1>
        <div class="group-actions-wrapper">
            <div class="clearfix group-actions" data-implement="fixed">
                <ul class="actions">
                    @if (Model.IsEditMode)
                    {
                        <li><a href="@Url.Action("List")" class="btn btn-medium"><span>Cancel</span></a></li>
                        <li><a href="@Url.Action("SaveSequence", new { Model.SequenceString })" class="btn btn-medium"><span>Save</span></a></li>
                    }
                    else
                    {
                        <li><a href="@Url.Action("EditSequence")" class="btn btn-medium"><span>Edit Sequence</span></a></li>
                        <li><a href="@Url.Action("Add")" class="btn btn-medium"><span>Add Special Collection</span></a></li>
                    }
                </ul>
            </div>
        </div>

        <div class="tablecontent">
            <table class="list">
                <thead>
                    <tr>
                        <th class="special_collection-details">Name</th>
                        <th>Is Public</th>
                        <th>Sequence</th>
                        <th>Resource Count</th>
                        <th>&nbsp;</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var specialCollectionList in Model.SpecialCollectionLists)
                    {
                        @Html.HiddenFor(x => specialCollectionList.Id)
                    <tr>
                        <td>@Html.ActionLink(specialCollectionList.Name, "Edit", new { collectionId = specialCollectionList.Id })</td>
                        <td>@Html.DisplayFor(x => specialCollectionList.IsPublic)</td>
                        @if (Model.IsEditMode)
                        {
                            <td>
                                <strong class="sort-type">
                                    <span class="ascending" title="Move Up">
                                        <a href="@Url.Action("SequenceMoveUp", new { collectionId = specialCollectionList.Id, sequenceString = Model.SequenceString })">Move Up</a>
                                    </span>
                                    <span class="descending" title="Move Down">
                                        <a href="@Url.Action("SequenceMoveDown", new { collectionId = specialCollectionList.Id, sequenceString = Model.SequenceString })">Move Down</a>
                                    </span>
                                </strong>
                            </td>
                        }
                        else
                        {
                            <td>@Html.DisplayFor(x => specialCollectionList.Sequence)</td>
                        }

                        <td>@Html.DisplayFor(x => specialCollectionList.ResourceCount)</td>
                        <td><a href="@Url.Action("Delete", new { collectionId = specialCollectionList.Id })" class="btn btn-medium btn-add" data-implement="modal"><span>Remove</span></a></td>
                    </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@section JsDocumentReady
{
    new R2V2.Admin.PdaCollection({ $parent: $('#container'), triggers: ['.btn-add'] });
}