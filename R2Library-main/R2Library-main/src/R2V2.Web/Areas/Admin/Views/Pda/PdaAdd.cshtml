@model R2V2.Web.Areas.Admin.Models.Cart.CollectionAdd
@{
	ViewBag.Title = "PDA Add";
	ViewBag.BodyCssClass = "admin";
	Layout = "~/Views/Shared/_LayoutModal.cshtml";
}

<div class="content collection-manage">
    <div class="modal-header">
        <h1>Add PDA to My Collection</h1>
        <a class="close" data-dismiss="modal" href="#">Close</a>
    </div>
            
    <div class="modal-body">
        <h2>@Model.InstitutionResource.Title</h2>
        <ul>
            <li>@Html.LabelFor(modelItem => Model.InstitutionResource.Isbn10) @Model.InstitutionResource.Isbn</li>
            <li>@Html.LabelFor(modelItem => Model.InstitutionResource.Authors) @Model.InstitutionResource.Authors</li>
            <li>@Html.LabelFor(modelItem => Model.InstitutionResource.PublisherName) @Model.InstitutionResource.PublisherName</li>
        </ul>

        @using (Html.BeginForm("PdaAdd", "Pda"))
		{            
            @Html.Hidden("AddPdaToCollection", "yes")
			@Html.Partial("../CollectionManagement/_HiddenQueryFields", Model.ResourceQuery)
			<div class="actions">
                <a class="cancel" data-dismiss="modal" href="#">Cancel</a>
                <button class="btn-medium" type="submit"><span>Add to PDA Collection</span></button>
            </div>
		}
    </div>
</div>

@section JsDocumentReady
{
    new R2V2.Admin.IFrameModal({ 
        $dismiss: $('a[data-dismiss="modal"]'),
        parent: window.parent
    });
}