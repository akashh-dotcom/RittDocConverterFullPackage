@model R2V2.Web.Areas.Admin.Models.PdaRules.PdaRuleResourcesModel

@{
    ViewBag.Title = "Verify Rule";
    ViewBag.BodyCssClass = "admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_Tabs")

@Html.Partial("ActionsMenus/_ActionsMenu", Model.ActionsMenu)

<div class="clearfix twocol-with-subnav contentcontainer">
    <div id="content" class="content collection-manage" role="main">
        <h1>@Model.PageTitle</h1>
        @Html.Partial("_InstitutionInfo")

        <p>
            @Html.Raw(Model.RuleGist.Description)<br />
            @Html.DisplayFor(x => Model.RuleGist.ResourcesToAdd)
            @if (Model.HideForm)
            {
                <span> @(StyleHelpers.MakePlural("Resource", Model.RuleGist.ResourcesToAdd)) added based on this task</span>

            }
            else
            {
                <span> @(StyleHelpers.MakePlural("Resource", Model.RuleGist.ResourcesToAdd)) based on this task</span>
            }
            
            
        </p>

        <div class="express-checkout-scroll">

            <ul>
                @foreach (var item in Model.ResourceString)
                {
                    <li>@Html.DisplayFor(x => item)</li>
                }
            </ul>
        </div>
        @if (Model.HideForm)
        {
            <div class="group-actions-wrapper">
                <div class="clearfix group-actions">
                    <ul class="actions">
                        <li><a class="btn btn-medium" href="@Url.Action("EditRule", "Pda", new {institutionId = Model.InstitutionId, ruleId = Model.RuleGist.RuleId})"><span>View Rule</span></a></li>
                        <li><a class="btn btn-medium" href="@Url.Action("PdaProfile", "Pda", new {institutionId = Model.InstitutionId})"><span>View PDA Profile</span></a></li>
                    </ul>
                </div>
            </div>
        }
        else
        {
            using (Html.BeginForm("RunRuleNow", "Pda"))
            {
                @Html.HiddenFor(x => x.InstitutionId)
                @Html.Hidden("RuleId", Model.RuleGist.RuleId)

                <div class="group-actions-wrapper">
                    <div class="clearfix group-actions">
                        <ul class="actions">
                            <li><a href="@Url.Action("EditRule", "Pda", new {institutionId = Model.InstitutionId, ruleId = Model.RuleGist.RuleId})">Cancel</a></li>
                            <li><button class="btn-medium" type="submit"><span>Add All To PDA</span></button></li>
                        </ul>
                    </div>
                </div>
            }
        }
    </div>

    @Html.Partial("_LeftNav", Model)
</div>

@section JsDocumentReady
{
    new R2V2.Admin.LeftNav({ $container: $('.admin-left-nav') });
}