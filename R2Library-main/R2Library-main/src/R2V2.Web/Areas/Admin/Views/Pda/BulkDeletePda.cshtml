@model R2V2.Web.Areas.Admin.Models.CollectionManagement.BulkDeletePda
@{
    ViewBag.Title = "PDA Delete";
    ViewBag.BodyCssClass = "admin";
    Layout = "~/Views/Shared/_LayoutModal.cshtml";
}

<div class="content collection-manage">
    <div class="modal-header">
        <h1>Bulk Delete PDA Resources</h1>
        <a class="close" data-dismiss="modal" href="#">Close</a>
    </div>

    <div class="modal-body">
        <div id="bulk-add-area">
            @if (!string.IsNullOrWhiteSpace(Model.IsbnsNotFound))
            {
                <h3>The following ISBNs are not active PDA resources:</h3>
                <p id="bulk-add-not-found">@Html.DisplayFor(model => model.IsbnsNotFound)</p>
            }
            @if (Model.ResourceCount > 0)
            {
                <h3>The following PDA resources will be deleted from your collection:</h3>
                <ul>
                    @foreach (var resource in Model.Resources)
                    {
                        <li>@resource.Title, ISBN: @resource.Isbn13</li>
                    }
                </ul>
                <p><strong>Resource Count: @Html.DisplayFor(model => model.ResourceCount)</strong></p>
            }
            else
            {
                <div><strong>Sorry, none of the resources selected are active PDA titles.</strong></div>
            }

            @if (Model.ExcludedResourceCount > 0)
            {
                <h3>The following resources are not active PDA resources:</h3>
                <ul>
                    @foreach (var resource in Model.ExcludedResources)
                    {
                        <li>@resource.Title, ISBN: @resource.Isbn13</li>
                    }
                </ul>
                <p><strong>Resource Count: @Html.DisplayFor(model => model.ExcludedResourceCount)</strong></p>
            }
        </div>

        @using (Html.BeginForm("BulkDeletePda", "Pda"))
        {
            @Html.Hidden("bulkDeletePda", "yes")
            @Html.Hidden("Resources", Model.CollectionManagementQuery.Resources)
            @Html.Partial("../CollectionManagement/_HiddenQueryFields", Model.CollectionManagementQuery)
            <div class="actions">
                <a class="cancel" data-dismiss="modal" href="#">Cancel</a>
                @if (Model.ResourceCount > 0)
                {
                    <button class="btn-medium" type="submit"><span>Delete All PDA Resources</span></button>
                }
            </div>
        }
    </div>
</div>

@section JsDocumentReady
{
    new R2V2.Admin.IFrameModal({ $dismiss: $('a[data-dismiss="modal"]'), parent: window.parent });
}