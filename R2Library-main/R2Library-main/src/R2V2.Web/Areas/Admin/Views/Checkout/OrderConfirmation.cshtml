@model R2V2.Web.Areas.Admin.Models.OrderHistory.OrderHistoryDetail

@{
    ViewBag.Title = "Order Confirmation";
    ViewBag.BodyCssClass = "admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_Tabs")

@Html.Partial("ActionsMenus/_ActionsMenu", Model.ActionsMenu)

<div class="clearfix twocol-with-subnav contentcontainer">
    <div id="content" class="content" role="main">
        <h1>Order Confirmation</h1>

        @Html.Partial("_InstitutionInfo")

        <div id="order-summary">
            <p>Thank you. Your order is being processed.</p>

            @Html.Partial("_OrderSummary", Model)
        </div>

        <div class="group-actions-wrapper">
            <div class="clearfix group-actions">
                <ul class="actions">
                    <li><a href="@Url.Action("Detail", "OrderHistory", new {institutionId = Model.InstitutionId, id = Model.OrderHistory.OrderHistoryId})" class="btn btn-medium"><span>View Order Summary</span></a></li>
                </ul>
            </div>
        </div>
    </div>

    @Html.Partial("_LeftNav", Model)
</div>
@section JsDocumentReady
{
    new R2V2.Admin.ActionsMenu({ $container: $('.actions-menu') });
    new R2V2.Admin.LeftNav({ $container: $('.admin-left-nav') });
}