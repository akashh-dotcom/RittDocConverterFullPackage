@model R2V2.Web.Areas.Admin.Models.Review.BulkAddToReview

@{
	ViewBag.Title = "Bulk Add Resources Confirm";
	ViewBag.BodyCssClass = "admin cm-modal-base recommend";
	Layout = "~/Views/Shared/_LayoutModal.cshtml";
}


<div class="content collection-manage">
    <div class="modal-header">
        <h1>Bulk Added Titles to Review List</h1>
        <a class="close" href="@Model.KeepShoppingLink" data-dismiss="navigation">Close</a>
    </div>
            
    <div class="modal-body">
		<div id="bulk-add-area">		
		    <h3>The following resources have been added to the review list:</h3>
		    <ul>		
			@foreach (var resource in Model.Resources)
			{
				<li>@resource.Title, ISBN: @resource.Isbn13 at @Html.DisplayFor(model => resource.DiscountPrice)</li>
			}
			</ul>
			<p><strong>Resource Count: @Html.DisplayFor(model => model.ResourceCount)</strong></p>
	    </div>
		<br />
		<div class="actions">
			<a href="@Url.Action("Detail", new { institutionId = Model.ResourceQuery.InstitutionId, reviewId = Model.ResourceQuery.ReviewId })" class="btn btn-medium" data-dismiss="navigation"><span>View Review List</span></a>
			<a href="@Url.Action("Resources", new { institutionId = Model.ResourceQuery.InstitutionId, reviewId = Model.ResourceQuery.ReviewId })" class="btn btn-medium" data-dismiss="navigation"><span>Add More Resources</span></a>
		</div>
	</div>
</div>
@section JsDocumentReady
{
    new R2V2.Admin.IFrameModal({
        parent: window.parent,
        $dismiss: $('a[data-dismiss="navigation"]')
    });
}