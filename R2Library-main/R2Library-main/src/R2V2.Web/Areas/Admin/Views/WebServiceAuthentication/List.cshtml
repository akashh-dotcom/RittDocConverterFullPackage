@model R2V2.Web.Areas.Admin.Models.WebServiceAuthentication.InstitutionWebServiceAuthenticationList
@{
    ViewBag.Title = "Institution Trusted Authentication";
    ViewBag.BodyCssClass = "admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_Tabs")

@Html.Partial("ActionsMenus/_ActionsMenu", Model.ActionsMenu)

<div class="clearfix twocol-with-subnav contentcontainer">
    <div id="content" class="content" role="main">
        <h1>Trusted Authentication Service</h1>
        
        @Html.Partial("_InstitutionInfo")
        
        <div class="group-actions-wrapper">
            <div class="clearfix group-actions" data-implement="fixed">
                <ul class="actions">
                    @if (Model.IsRittenhouseAdmin || Model.IsSalesAssociate)
                    {
                        <li><a href="@Url.Action("Add", new { institutionId = Model.InstitutionId })" class="btn btn-medium"><span>Add New</span></a></li>
                    }
                    
                </ul>
            </div>
        </div>
        
        @if (Model.TrustedAuths != null && Model.TrustedAuths.Any())
        {
            <div class="tablecontent">
                <table class="list">
                    <thead>
                        <tr>
                            <th>IP Address</th>
                            <th>Web Service Authentication Key</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.TrustedAuths)
                        {
                            <tr>
                                <td>@Html.DisplayFor(x => item.OctetA).@Html.DisplayFor(x => item.OctetB).@Html.DisplayFor(x => item.OctetC).@Html.DisplayFor(x => item.OctetD)</td>
                                <td>@Html.DisplayFor(x => item.AuthenticationKey)</td>
                                <td class="actions">
                                    @if (Model.IsRittenhouseAdmin || Model.IsSalesAssociate)
                                    {
                                        
                                    
                                    <a href="@Url.Action("Edit", new { institutionId = Model.InstitutionId, institutionTrustedAuthenticationId = item.Id })" class="btn btn-medium"><span>Edit</span></a> 
                                        <a href="@Url.Action("Delete", new { institutionId = Model.InstitutionId, institutionTrustedAuthenticationId = item.Id })" class="btn btn-medium"><span>Delete</span></a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p><strong>No Trusted Authenications Available.</strong></p>
        }
    </div>

    @Html.Partial("_LeftNav", Model)
</div>

@section JsDocumentReady
{
    new R2V2.Admin.ActionsMenu({ $container: $('.actions-menu') });
    new R2V2.Admin.LeftNav({ $container: $('.admin-left-nav') });
}