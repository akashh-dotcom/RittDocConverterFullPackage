@model R2V2.Web.Areas.Admin.Models.InstitutionCrawlerBypass.InstitutionCrawlerBypassList
@{
    ViewBag.Title = "Institution Crawler Bypass";
    ViewBag.BodyCssClass = "admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_Tabs")

@Html.Partial("ActionsMenus/_ActionsMenu", Model.ActionsMenu)


<div class="clearfix twocol-with-subnav contentcontainer">
    <div id="content" class="content" role="main">
        <h1>Institution Crawler Bypass</h1>
        
        @Html.Partial("_InstitutionInfo")
        
        <div class="group-actions-wrapper">
            <div class="clearfix group-actions" data-implement="fixed">
                <ul class="actions">
                    @if (Model.IsRittenhouseAdmin || Model.IsSalesAssociate)
                    {
                        <li><a href="@Url.Action("Add", new { institutionId = Model.InstitutionId })" class="btn btn-medium"><span>Add New</span></a></li>
                    }
                    
                </ul>
            </div>
        </div>
        
        @if (Model.InstitutionCrawlerBypassModels.Any())
        {
            <div class="tablecontent">
                <table class="list">
                    <thead>
                        <tr>
                            <th>IP Address</th>
                            <th>User Agent</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.InstitutionCrawlerBypassModels)
                        {
                            <tr>
                                <td>@Html.DisplayFor(x => item.OctetA).@Html.DisplayFor(x => item.OctetB).@Html.DisplayFor(x => item.OctetC).@Html.DisplayFor(x => item.OctetD)</td>
                                <td>@Html.DisplayFor(x => item.UserAgent)</td>
                                <td class="actions">                                   
                                    <a href="@Url.Action("Edit", new { institutionId = Model.InstitutionId, institutionCrawlerBypassId = item.Id })" class="btn btn-medium"><span>Edit</span></a> 
                                    <a href="@Url.Action("Delete", new { institutionId = Model.InstitutionId, institutionCrawlerBypassId = item.Id })" class="btn btn-medium"><span>Delete</span></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p><strong>No Crawler Bypasses Available.</strong></p>
        }
    </div>

    @Html.Partial("_LeftNav", Model)
</div>

@section JsDocumentReady
{
    new R2V2.Admin.ActionsMenu({ $container: $('.actions-menu') });
    new R2V2.Admin.LeftNav({ $container: $('.admin-left-nav') });
}
