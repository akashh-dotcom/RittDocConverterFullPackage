@using R2V2.Core.CollectionManagement
@using R2V2.Web.Areas.Admin.Models
@model R2V2.Web.Areas.Admin.Models.Cart.CollectionAdd
@{
	ViewBag.Title = "Express Check Out";
	ViewBag.BodyCssClass = "admin";
	Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_Tabs")

@Html.Partial("ActionsMenus/_ActionsMenu", Model.ActionsMenu)

<div class="clearfix twocol-with-subnav contentcontainer">
    <div id="content" class="content collection-manage" role="main">
        <h1>R2 Digital Library</h1>
		<div id="bulk-service-agreement">
			<p>You are about to create an R2 PDA Collection.</p>
			<p>This will end your trial.</p>
		</div>
        @using (Html.BeginForm("PdaTrialConvertModal", "ExpressCheckout"))
		{   
			@Html.Partial("../CollectionManagement/_HiddenQueryFields", Model.ResourceQuery)
            
			<div class="group-actions-wrapper">
				<div class="clearfix group-actions">
				    <ul class="actions">
				        @if (Model.ResourceQuery.IsPdaProfile)
				        {
                            <li><a href="@Url.Action("PdaProfile", "Pda", Model.ResourceQuery.ToRouteValues())">Cancel</a></li>
				        }
				        else
				        {
				            <li><a href="@Url.Action("Index", new CollectionManagementQuery{InstitutionId = Model.InstitutionId}.ToRouteValues())">Cancel</a></li>
				        }
				        
				        <li><button class="btn-medium" type="submit"><span>Continue</span></button></li>
				    </ul>
				</div>
			</div>
		}		
    </div>

    @Html.Partial("_LeftNav", Model)
</div>

@section JsDocumentReady
{
    new R2V2.Admin.LeftNav({ $container: $('.admin-left-nav') });
}