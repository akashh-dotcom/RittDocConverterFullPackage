@model R2V2.Web.Areas.Admin.Models.AdminBaseModel

@if (Model != null && Model.TabLinks != null && Model.TabLinks.Any())
{
    <div class="tabs">
        <ul class="clearfix">
            @foreach(var link in Model.TabLinks)
            {
                <li@(StyleHelpers.AddSelectedState(link.Selected))><a href="@link.Href"><span>@link.Text</span></a></li>    
            }
        </ul>
    </div>
}