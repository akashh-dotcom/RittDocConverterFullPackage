@model R2V2.Web.Areas.Admin.Models.Menus.ActionsMenu
           
@if (Model.DisplayCartLink)
{
    <li class="pull-right">
        <a href="#shopping-cart" class="shopping-cart" role="button" aria-expanded="false" aria-controls="shopping-cart">Shopping Cart (@Model.CartItemCount)</a>
        <div id="shopping-cart" class="megamenu" data-panel="shoppingcart">
            @if (Model.ResellerCartList != null)
            {
                <div style="float: left">
                    <span><b>Reseller Order: </b></span>
                    @Html.DropDownList("reseller-dropdown", Model.ResellerCartList)
                    <a class="btn btn-medium reseller-link" href="@Model.ResellerLinkHref"><span>create</span></a>
                </div>
            }
  
            
            <ul>
                <li><strong>Items:</strong> @Model.CartItemCount</li>
                <li><strong>Total:</strong> @Html.DisplayFor(x => Model.CartTotal)</li>
                <li><a class="btn btn-medium" href="@Url.Action("ShoppingCart", "Cart", new {institutionId = Model.InstitutionId, Model.CartId})"><span>View Cart</span></a></li>
                @if (Model.CartItemCount > 0)
                {
                    <li><a class="btn btn-medium" href="@Url.Action("Checkout", "Checkout", new {institutionId = Model.InstitutionId, Model.CartId})"><span>Checkout</span></a></li>
                }
        
            </ul>
        </div>
    </li>
}

