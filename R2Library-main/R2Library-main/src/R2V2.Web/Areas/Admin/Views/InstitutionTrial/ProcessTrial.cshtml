@model R2V2.Web.Areas.Admin.Models.TrialInstitution.TrialInstitution
@{
    ViewBag.Title = "Create Trial Institution";
    ViewBag.BodyCssClass = "admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_Tabs")

<div class="fullcol contentcontainer">
    <div id="content" class="content" role="main">
        <h1>Trial Institution</h1>

        @Html.Partial("_ProcessTrial", Model)
    </div>
    <input type="hidden" id="WasSubmitted" value="false"/>
</div>

@section JsDocumentReady{
    $('#SubmitTrial').on('click',function() {
        if($('#trialForm').valid()){
            $(this).prop("disabled",true);
        }
    });
}