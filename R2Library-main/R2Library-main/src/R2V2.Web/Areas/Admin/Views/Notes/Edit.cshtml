@model R2V2.Web.Areas.Admin.Models.Notes.NotesEdit
@{
    ViewBag.Title = "Institution Notes";
    ViewBag.BodyCssClass = "admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_Tabs")

@Html.Partial("ActionsMenus/_ActionsMenu", Model.ActionsMenu)

<div class="clearfix twocol-with-subnav contentcontainer">
    <div id="content" class="content" role="main">
        <h1>Institution Note</h1>
        
        @Html.Partial("_InstitutionInfo")

        @using (Html.BeginForm()){
            <div class="group-actions-wrapper"><div class="clearfix group-actions" data-implement="fixed">
                <ul class="actions">
                    <li><button type="submit" class="btn btn-medium"><span>Save</span></button></li>
                    <li><a data-history="back" class="btn btn-medium"><span>Cancel</span></a></li>
                </ul>
            </div></div>
            
            <div class="tablecontent">
                @Html.ValidationMessageFor(x => x.Note)
                @Html.HiddenFor(x=>x.Note.InstitutionId)
                @Html.HiddenFor(x=>x.Note.Id)
                @Html.HiddenFor(x=>x.Note.UserId)

                <table class="edit">
                    <tbody>
                        @if(Model.Note.Id != 0)
                        {
                            <tr>
                                <td class="label">@Html.LabelFor(x => Model.Note.CreatedBy)</td>
                                <td class="field">@Html.DisplayFor(x => Model.Note.CreatedBy)</td>
                            </tr>
                            <tr>
                                <td class="label">@Html.LabelFor(x => Model.Note.UpdatedBy)</td>
                                <td class="field">@Html.DisplayFor(x => Model.Note.UpdatedBy)</td>
                            </tr>
                            <tr>
                                <td class="label">@Html.LabelFor(x => Model.Note.LastUpdated)</td>
                                <td class="field">@Html.Raw(Model.Note.LastUpdated == DateTime.MinValue ? DateTime.Now.ToShortDateString() : Model.Note.LastUpdated.ToShortDateString())</td>
                            </tr>
                        }
                        <tr>
                            <td class="label">@Html.LabelFor(x => Model.Note.Comment)</td>
                            <td class="field">
                                @Html.TextAreaFor(x => x.Note.Comment)
                                @Html.ValidationMessageFor(x => x.Note.Comment)
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }
    </div>

    @Html.Partial("_LeftNav", Model)
</div>

@section JsDocumentReady
{
    new R2V2.Admin.ActionsMenu({ $container: $('.actions-menu') });
    new R2V2.Admin.LeftNav({ $container: $('.admin-left-nav') });
}