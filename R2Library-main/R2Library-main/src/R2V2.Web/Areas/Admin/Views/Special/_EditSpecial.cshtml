@model R2V2.Web.Areas.Admin.Models.Special.SpecialView

<div class="tablecontent">
    @Html.HiddenFor(x => x.Special.Id)
    
    <table class="edit">
        <tbody>
            <tr>
                <td class="label">@Html.LabelFor(x => x.Special.Name)</td>
                <td class="field">
                    @Html.EditorFor(x => x.Special.Name, new { @class = "input-large", placeholder = "Will be displayed in resource details" })
                    @Html.ValidationMessageFor(x => x.Special.Name)
                </td>
            </tr>
            
            <tr>
                <td class="label">@Html.LabelFor(x => x.Special.StartDate)</td>
                <td class="field">
                    @Html.EditorFor(x => x.Special.StartDate, new { @class = "input-medium", placeholder = "e.g. 01/01/2014" })
                    @Html.ValidationMessageFor(x => x.Special.StartDate)
                </td>
            </tr>

            <tr>
                <td class="label">@Html.LabelFor(x => x.Special.EndDate)</td>
                <td class="field">
                    @Html.EditorFor(x => x.Special.EndDate, new { @class = "input-medium", placeholder = "e.g. 01/01/2014" })
                    @Html.ValidationMessageFor(x => x.Special.EndDate)
                </td>
            </tr>
        </tbody>
    </table>
</div>
