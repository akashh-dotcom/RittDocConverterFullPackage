@model R2V2.Web.Areas.Admin.Models.User.AdminUserEmailOptions

@{
    ViewBag.Title = "User Email Options";
    ViewBag.BodyCssClass = "admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_Tabs")
@Html.Partial("ActionsMenus/_ActionsMenu", Model.ActionsMenu)

<div class="clearfix twocol-with-subnav contentcontainer">
    <div id="content" class="content" role="main">
        <h1>Email Preferences</h1>
        @Html.Partial("_InstitutionInfo")
        
        <div class="institution-info">
            <p>@Html.Raw(Model.UserDescription)</p>
        </div>

        @Html.Partial("_Email")
    </div>

    @Html.Partial("_LeftNav", Model)
</div>

@section JsDocumentReady
{
    new R2V2.Admin.LeftNav({ $container: $('.admin-left-nav') });

    $.CopySelectedRadioToHidden({
        form : '#EmailOptionForm',
        hiddenChecked : '#SubscribedOptions',
        hiddenUnChecked : '#UnSubscribedOptions',
        button : '#SubmitButton'
    });   
}

