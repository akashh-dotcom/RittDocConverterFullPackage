@model R2V2.Web.Areas.Admin.Models.SystemInformation.Outreach
@{
    ViewBag.Title = "R2 Outreach";
    ViewBag.BodyCssClass = "admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.Partial("_Tabs")

<div class="clearfix twocol-with-subnav contentcontainer">
    <div id="content" class="content" role="main">
        <h1>R2 Outreach</h1>
        
        <ul class="list-links">
            <li><a href="/_Static/Downloads/r2-library-quickstart.pdf" class="icon pdf-file" target="_blank" data-toggle="window">Quick Start</a> <span class="stamp-fileinfo">(PDF, 2.8M)</span></li>
            <li><a href="/_Static/Downloads/r2-library-demo-end-user.pptx" class="icon ppt-file" target="_blank" data-toggle="window">Power Point Demonstration, End Users</a> <span class="stamp-fileinfo">(PPTX, 3.5M)</span></li>
            <li><a href="/_Static/Downloads/r2-library-demo-admin.pptx" class="icon ppt-file" target="_blank" data-toggle="window">Power Point Demonstration, Administrators</a> <span class="stamp-fileinfo">(PPTX, 4.1M)</span></li>
            <li><a href="/_Static/Downloads/r2-library-trial-announcement.pdf" class="icon pdf-file" target="_blank" data-toggle="window">R2 Library Trial Announcement</a> <span class="stamp-fileinfo">(PDF, 0.3M)</span></li>
            <li><a href="/_Static/Downloads/r2-library-admin-user-guide.pdf" class="icon pdf-file" target="_blank" data-toggle="window">R2 Library Admin User Guide</a> <span class="stamp-fileinfo">(PDF, 1.5M)</span></li>
            <li><a href="/_Static/Downloads/r2-library-pda-guide.pdf" class="icon pdf-file" target="_blank" data-toggle="window">R2 Library PDA Quick Start Guide</a> <span class="stamp-fileinfo">(PDF, 1.5M)</span></li>
            <li><a href="/_Static/Downloads/r2-library-expert-review-quick-guide.pdf" class="icon pdf-file" target="_blank" data-toggle="window">Expert Reviewer Quick Guide (for Administrators)</a> <span class="stamp-fileinfo">(PDF, 0.9M)</span></li>
            <li><a href="/_Static/Downloads/r2-library-expert-review-guide.pdf" class="icon pdf-file" target="_blank" data-toggle="window">Expert Reviewer Guide (for Expert Reviewer users)</a> <span class="stamp-fileinfo">(PDF, 0.4M)</span></li>
            <li><a href="/_Static/Downloads/r2-library-pda-wizard-guide.pdf" class="icon pdf-file" target="_blank" data-toggle="window">PDA Wizard Quick Start Guide (for Administrators)</a> <span class="stamp-fileinfo">(PDF, 0.7M)</span></li>
            
            @*<li><a href="#precision-search-video" data-toggle="modal">Precision Search Demonstration Video</a></li>*@
        </ul>
        
        <p>R2 Digital Library Logo</p>

        <div class="clearfix download-asset">
            <img alt="R2 Digital Library" src="/_Static/Images/r2-digital-library.png" height="67" />
            <ul class="list-links">
                <li><a href="/_Static/Images/r2-digital-library.png" class="img-file" target="_blank" data-toggle="window">Large Format</a> <span class="stamp-fileinfo">(GIF, 4.2K, 179 x 67)</span></li>
                <li><a href="/_Static/Images/r2-digital-library.png" class="img-file" target="_blank" data-toggle="window">Small Format</a> <span class="stamp-fileinfo">(GIF, 2.9K, 112 x 41)</span></li>
            </ul>
        </div>
    </div>
    
    @Html.Partial("_LeftNav")
</div>

@section InlineModal
{
    <div id="precision-search-video" class="content modal delete" >
        <div class="modal-header">
            <h1>Precision Search Demonstration Video</h1>
            <a class="close" data-dismiss="modal" href="#">Close</a>
        </div>
        
        <div class="modal-body">
            <div style="width: 50%; margin: 0 auto;">
                <object width="420" height="315"  >
                    <param name="movie" value="//www.youtube.com/v/oO8lJMtJdFI?hl=en_US&amp;version=3" />
                    <param name="allowFullScreen" value="true" />
                    <param name="allowscriptaccess" value="always" />
                    <embed id="psVideo" src="http://www.youtube.com/v/oO8lJMtJdFI?version=3&enablejsapi=1" type="application/x-shockwave-flash" width="420" height="315" allowscriptaccess="always" allowfullscreen="true" />
                </object>
            </div>
        </div>
    </div>

}
@section JsDocumentReady{
    new R2V2.Admin.LeftNav({ $container: $('.admin-left-nav') });

    $('#precision-search-video').on('hide', function () {
    var myPlayer = document.getElementById('psVideo');
        myPlayer.stopVideo();
    });
}
