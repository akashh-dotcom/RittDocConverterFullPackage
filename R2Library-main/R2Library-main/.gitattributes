# Ensure consistent line endings for text files
* text=auto eol=lf

# C# source files
*.cs     text diff=csharp
*.csx    text

# Project and solution files
*.sln    text eol=crlf
*.csproj text eol=crlf
*.vbproj text eol=crlf
*.fsproj text eol=crlf
*.dbproj text eol=crlf

# Config and metadata
*.config   text
*.json     text
*.xml      text
*.props    text
*.targets  text
*.xaml     text
*.yml      text
*.yaml     text
*.md       text
*.txt      text

# PowerShell / shell / scripts
*.ps1   text eol=crlf
*.sh    text eol=lf
*.cmd   text eol=crlf
*.bat   text eol=crlf

# Binary files
*.dll binary
*.exe binary
*.pdb binary
*.so  binary
*.dylib binary

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Archives
*.zip  binary
*.tar  binary
*.gz   binary
*.7z   binary

# NuGet packages
*.nupkg binary
*.snupkg binary

# Visual Studio specific
*.vsix binary

