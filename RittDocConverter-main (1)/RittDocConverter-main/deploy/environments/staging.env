# Staging Environment
# ====================
# Use this for staging/QA deployments

ENVIRONMENT=staging

# =============================================================================
# Service URLs (via API Gateway)
# =============================================================================
# All services accessed through the gateway
API_GATEWAY_URL=https://api-staging.rittdoc.example.com

# Internal service URLs (for inter-service communication)
EPUB_SERVICE_URL=http://epub-service:5001

# External URLs (what clients/browsers use)
EPUB_SERVICE_EXTERNAL_URL=https://api-staging.rittdoc.example.com/epub
UI_SERVICE_EXTERNAL_URL=https://staging.rittdoc.example.com

# =============================================================================
# Database
# =============================================================================
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=rittdoc_staging
# For managed MongoDB (Atlas, DocumentDB):
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/rittdoc_staging

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=5001
API_DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# Processing
# =============================================================================
MAX_CONCURRENT_JOBS=4
JOB_TIMEOUT_SECONDS=3600

# =============================================================================
# Storage (S3)
# =============================================================================
S3_ENABLED=true
S3_BUCKET_NAME=rittdoc-staging
S3_REGION=us-east-1
# AWS credentials via IAM role or:
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx

# =============================================================================
# Security
# =============================================================================
CORS_ALLOWED_ORIGINS=https://staging.rittdoc.example.com
# API_KEY_REQUIRED=true
# API_KEY=staging-api-key-here

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_SWAGGER_UI=true
ENABLE_DEBUG_ENDPOINTS=false
ENABLE_CORS_ALL_ORIGINS=false
