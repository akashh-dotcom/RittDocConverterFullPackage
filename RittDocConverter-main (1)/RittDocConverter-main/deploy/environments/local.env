# Local Development Environment
# ==============================
# Use this for local development with docker-compose

ENVIRONMENT=development

# =============================================================================
# Service URLs (Internal Docker Network)
# =============================================================================
EPUB_SERVICE_URL=http://epub-service:5001
UI_SERVICE_URL=http://ui:3000

# External URLs (for browser access)
EPUB_SERVICE_EXTERNAL_URL=http://localhost:5001
UI_SERVICE_EXTERNAL_URL=http://localhost:3000

# =============================================================================
# Database
# =============================================================================
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=rittdoc_converter

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=5001
API_DEBUG=true
LOG_LEVEL=DEBUG

# =============================================================================
# Processing
# =============================================================================
MAX_CONCURRENT_JOBS=2
JOB_TIMEOUT_SECONDS=3600

# =============================================================================
# Storage (Local)
# =============================================================================
S3_ENABLED=false
LOCAL_STORAGE_PATH=/app/Output

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_SWAGGER_UI=true
ENABLE_DEBUG_ENDPOINTS=true
ENABLE_CORS_ALL_ORIGINS=true
