# Production Environment
# =======================
# Use this for production deployments

ENVIRONMENT=production

# =============================================================================
# Service URLs (via API Gateway)
# =============================================================================
API_GATEWAY_URL=https://api.rittdoc.example.com

# Internal service URLs (for inter-service communication)
EPUB_SERVICE_URL=http://epub-service:5001

# External URLs (what clients/browsers use)
EPUB_SERVICE_EXTERNAL_URL=https://api.rittdoc.example.com/epub
UI_SERVICE_EXTERNAL_URL=https://app.rittdoc.example.com

# =============================================================================
# Database (Production MongoDB)
# =============================================================================
# Use managed MongoDB (Atlas, DocumentDB) with authentication
MONGODB_URI=mongodb+srv://produser:${MONGO_PASSWORD}@prod-cluster.mongodb.net/rittdoc_prod?retryWrites=true&w=majority
MONGODB_DATABASE=rittdoc_prod

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=5001
API_DEBUG=false
LOG_LEVEL=WARNING

# =============================================================================
# Processing
# =============================================================================
MAX_CONCURRENT_JOBS=8
JOB_TIMEOUT_SECONDS=7200

# =============================================================================
# Storage (S3 Production)
# =============================================================================
S3_ENABLED=true
S3_BUCKET_NAME=rittdoc-production
S3_REGION=us-east-1
# Use IAM roles for credentials, not env vars

# =============================================================================
# Security
# =============================================================================
CORS_ALLOWED_ORIGINS=https://app.rittdoc.example.com
API_KEY_REQUIRED=true
# API_KEY loaded from secrets manager

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_SWAGGER_UI=false
ENABLE_DEBUG_ENDPOINTS=false
ENABLE_CORS_ALL_ORIGINS=false

# =============================================================================
# Monitoring
# =============================================================================
ENABLE_METRICS=true
METRICS_PORT=9090
# SENTRY_DSN=https://xxx@sentry.io/xxx
