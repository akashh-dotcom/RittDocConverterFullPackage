# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts must always have Unix line endings (LF)
*.sh text eol=lf
docker-entrypoint.sh text eol=lf

# Batch files need Windows line endings
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.epub binary
*.zip binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Keep these as-is
*.xml text
*.json text
*.py text
*.md text
*.txt text
*.yml text
*.yaml text
