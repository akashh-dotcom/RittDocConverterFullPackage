# RittDocConverter Environment Configuration
# ============================================
# Copy this file to .env and configure your settings
#
# NEVER commit .env to version control!

# =============================================================================
# API Configuration
# =============================================================================
EPUB_API_PORT=5001
API_DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# Editor Configuration
# =============================================================================
EDITOR_PORT=5000

# =============================================================================
# MongoDB Configuration
# =============================================================================
# OPTION 1: External/Shared MongoDB (RECOMMENDED for production)
# Use this when MongoDB is hosted separately or shared with other services
# MONGODB_URI=mongodb://admin:password@your-mongodb-host:27017

# OPTION 2: MongoDB Atlas (managed cloud)
# MONGODB_URI=mongodb+srv://user:password@cluster0.lk4msmt.mongodb.net/RittenhouseXMLConverter?appName=Cluster0

# OPTION 3: Local MongoDB (for development only)
# Start with: docker-compose --profile mongodb up -d
MONGODB_URI=mongodb://mongodb:27017

# Database settings (shared across all pipelines)
MONGODB_DATABASE=RittenhouseXMLConverter
MONGODB_COLLECTION=conversion_dashboard

# MongoDB Authentication (for shared/production MongoDB)
MONGO_USER=admin
MONGO_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Local MongoDB port (only used with --profile mongodb)
MONGODB_PORT=27017

# =============================================================================
# Processing Configuration
# =============================================================================
MAX_CONCURRENT_JOBS=4
JOB_TIMEOUT_SECONDS=3600

# =============================================================================
# S3/Cloud Storage Configuration (optional)
# =============================================================================
S3_ENABLED=false
S3_BUCKET_NAME=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =============================================================================
# Email Notifications (optional)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# =============================================================================
# Development Tools
# =============================================================================
# MongoDB Express (admin UI) - only with --profile mongodb
MONGO_EXPRESS_PORT=8081
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin

# =============================================================================
# Service URLs (for multi-service setup)
# =============================================================================
# These are used when services need to communicate with each other
EPUB_SERVICE_URL=http://epub-service:5001
EDITOR_SERVICE_URL=http://editor:5000
UI_SERVICE_URL=http://ui:3000

# =============================================================================
# Shared MongoDB Infrastructure (separate deployment)
# =============================================================================
# If using deploy/infrastructure/docker-compose.mongodb.yml:
# MONGODB_URI=mongodb://admin:changeme@host.docker.internal:27017
#
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://rittdoc:password@cluster0.xxxxx.mongodb.net/rittdoc
